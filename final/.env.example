# ── BACKEND (Railway / Docker) ────────────────────────────────

# Puerto del servidor (Railway lo asigna automáticamente con $PORT)
PORT=8070

# Conexión a Supabase PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.mgssrqfsmbitiobsvrlw
SPRING_DATASOURCE_PASSWORD=fUVzg4B9xLb7piJx

# Modo DDL: "update" en dev, "validate" en producción
DDL_AUTO=validate

# Orígenes CORS permitidos (separados por coma, sin espacios)
# Reemplaza con la URL real de tu frontend en Vercel
CORS_ALLOWED_ORIGINS=https://marazulfront.onrender.com,http://localhost:5173,http://localhost:3000

# ── FRONTEND (Vercel) ─────────────────────────────────────────

# URL base del backend desplegado (sin barra final)
# Reemplaza con la URL real de tu backend en Railway
VITE_API_URL=https://marazulback.onrender.com
